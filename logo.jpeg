    <!-- SERVICES -->
    <section id="services" class="section-pad">
      <div class="container">
        <div class="section-header">
          <span class="section-label reveal">What We Do</span>
          <h2 class="reveal">Digital Services That <span class="gradient-text">Drive Growth</span></h2>
          <p class="reveal">From stunning websites to viral social campaigns — we provide everything your business needs to dominate online.</p>
        </div>
        <div class="services-grid">
          <div class="service-card reveal">
            <div class="service-icon">
              <svg width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
            </div>
            <h3>Web Design</h3>
            <p>Pixel-perfect, blazing-fast websites that look incredible on every device and convert visitors into customers.</p>
            <a href="pricing.html" class="btn btn-ghost" style="margin-top: 1.5rem; font-size: 0.85rem; padding: 0.6rem 1.2rem;">
              <span>See Plans</span>
              <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
          <div class="service-card reveal">
            <div class="service-icon">
              <svg width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" aria-hidden="true"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
            </div>
            <h3>Facebook Ads</h3>
            <p>Hyper-targeted ad campaigns that reach your ideal customers and deliver a measurable return on every rupee spent.</p>
            <a href="contact.html" class="btn btn-ghost" style="margin-top: 1.5rem; font-size: 0.85rem; padding: 0.6rem 1.2rem;">
              <span>Get Started</span>
              <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
          <div class="service-card reveal">
            <div class="service-icon">
              <svg width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" aria-hidden="true"><path d="M21 2H3v16h5v4l4-4h9V2z"/><path d="M10 8h4M8 12h8"/></svg>
            </div>
            <h3>TikTok Marketing</h3>
            <p>Viral-ready content strategies and paid campaigns that put your brand in front of millions of potential customers.</p>
            <a href="contact.html" class="btn btn-ghost" style="margin-top: 1.5rem; font-size: 0.85rem; padding: 0.6rem 1.2rem;">
              <span>Grow Now</span>
              <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
          <div class="service-card reveal">
            <div class="service-icon">
              <svg width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87L18.18 21 12 17.77 5.82 21 7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            </div>
            <h3>Admin Panel Integration</h3>
            <p>Custom dashboard systems and CMS integrations that give you full control over your website content — no tech skills needed.</p>
            <a href="contact.html" class="btn btn-ghost" style="margin-top: 1.5rem; font-size: 0.85rem; padding: 0.6rem 1.2rem;">
              <span>Learn More</span>
              <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- PROCESS -->
    <section id="process" style="background: var(--clr-bg-raised); border-top: 1px solid var(--clr-border); border-bottom: 1px solid var(--clr-border);">
      <div class="container section-pad">
        <div class="section-header">
          <span class="section-label reveal">How It Works</span>
          <h2 class="reveal">From Concept to <span class="gradient-text">Launch in 4 Steps</span></h2>
          <p class="reveal">Our streamlined process ensures every project is delivered on time, on budget, and beyond expectations.</p>
        </div>
        <div class="process-steps">
          <div class="process-step reveal">
            <div class="step-number">01</div>
            <h4 class="step-title">Discovery Call</h4>
            <p class="step-desc">We listen to your goals, understand your brand, and define the perfect digital strategy for your business.</p>
          </div>
          <div class="process-step reveal">
            <div class="step-number">02</div>
            <h4 class="step-title">Design & Plan</h4>
            <p class="step-desc">Our designers craft wireframes and visual concepts tailored to your brand identity and target audience.</p>
          </div>
          <div class="process-step reveal">
            <div class="step-number">03</div>
            <h4 class="step-title">Build & Test</h4>
            <p class="step-desc">We develop your digital assets with clean code, then rigorously test across all devices and browsers.</p>
          </div>
          <div class="process-step reveal">
            <div class="step-number">04</div>
            <h4 class="step-title">Launch & Support</h4>
            <p class="step-desc">Your project goes live and we provide ongoing support to ensure everything performs perfectly.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- TESTIMONIALS -->
    <section id="testimonials" class="section-pad">
      <div class="container">
        <div class="section-header">
          <span class="section-label reveal">Client Stories</span>
          <h2 class="reveal">What Our Clients <span class="gradient-text">Say About Us</span></h2>
        </div>
        <div class="carousel reveal" aria-label="Client testimonials" role="region" aria-live="polite">
          <div class="testimonial-quote" aria-hidden="true">"</div>
          <div class="carousel-track">
            <div class="carousel-slide testimonial-slide">
              <div class="stars">★★★★★</div>
              <p class="testimonial-text">The BIT Group transformed our outdated website into a stunning, high-converting platform. Our online sales increased by 340% in the first three months after launch. Absolutely phenomenal work!</p>
              <div class="testimonial-avatar">SK</div>
              <p class="testimonial-name">Samantha K.</p>
              <p class="testimonial-role">CEO, Fashion Boutique — Colombo</p>
            </div>
            <div class="carousel-slide testimonial-slide">
              <div class="stars">★★★★★</div>
              <p class="testimonial-text">Their Facebook Ads campaigns are on another level. We spent LKR 50,000 on ads and generated over LKR 400,000 in revenue in just 30 days. The team is professional, responsive, and genuinely passionate.</p>
              <div class="testimonial-avatar">RP</div>
              <p class="testimonial-name">Ranil P.</p>
              <p class="testimonial-role">Owner, Electronics Store — Kandy</p>
            </div>
            <div class="carousel-slide testimonial-slide">
              <div class="stars">★★★★★</div>
              <p class="testimonial-text">From the initial call to the final launch, the experience was seamless. They understood our vision immediately and delivered a website that perfectly represents our brand. Highly recommended!</p>
              <div class="testimonial-avatar">AM</div>
              <p class="testimonial-name">Amara M.</p>
              <p class="testimonial-role">Director, Restaurant Chain — Galle</p>
            </div>
          </div>
          <div class="carousel-controls">
            <button class="carousel-btn prev" aria-label="Previous testimonial">
              <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M15 18l-6-6 6-6"/></svg>
            </button>
            <button class="carousel-dot active" aria-label="Testimonial 1"></button>
            <button class="carousel-dot" aria-label="Testimonial 2"></button>
            <button class="carousel-dot" aria-label="Testimonial 3"></button>
            <button class="carousel-btn next" aria-label="Next testimonial">
              <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 18l6-6-6-6"/></svg>
            </button>
          </div>
        </div>
      </div>
    </section>

